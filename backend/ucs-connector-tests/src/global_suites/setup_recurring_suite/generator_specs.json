{
  "suite": "setup_recurring",
  "rpc": "PaymentService.SetupRecurring",
  "success": {
    "status": [],
    "error": "must_not_exist",
    "must_exist": ["mandate_reference.connector_mandate_id.connector_mandate_id"]
  },
  "groups": {
    "required": {
      "fields": {
        "merchant_recurring_payment_id": {
          "source": "auto"
        },
        "amount": {
          "source": "static",
          "value": {"minor_amount": 6000},
          "variants": {
            "field": "currency",
            "values": ["USD", "EUR", "GBP"]
          }
        },
        "payment_method": {
          "source": "data_file",
          "variants": ["card"]
        },
        "address": {
          "source": "auto"
        },
        "auth_type": {
          "source": "enum",
          "variants": ["NO_THREE_DS", "THREE_DS"]
        },
        "enrolled_for_3ds": {
          "source": "static",
          "value": false
        },
        "customer_acceptance": {
          "source": "static",
          "value": {"acceptance_type": "OFFLINE"}
        },
        "setup_future_usage": {
          "source": "static",
          "value": "OFF_SESSION"
        },
        "state.access_token.token.value": {
          "source": "prev_service",
          "suite": "create_access_token"
        },
        "state.access_token.token_type": {
          "source": "prev_service",
          "suite": "create_access_token"
        },
        "state.access_token.expires_in_seconds": {
          "source": "prev_service",
          "suite": "create_access_token"
        }
      }
    },
    "customer_information": {
      "fields": {
        "customer.name": {
          "source": "auto"
        },
        "customer.email": {
          "source": "auto"
        },
        "customer.id": {
          "source": "auto"
        },
        "customer.phone_number": {
          "source": "auto"
        },
        "customer.connector_customer_id": {
          "source": "prev_service",
          "suite": "create_customer"
        }
      }
    },
    "urls_and_webhooks": {
      "fields": {
        "return_url": {
          "source": "static",
          "value": "https://example.com/payment/return"
        },
        "webhook_url": {
          "source": "static",
          "value": "https://example.com/payment/webhook"
        },
        "complete_authorize_url": {
          "source": "static",
          "value": "https://example.com/payment/complete"
        }
      }
    },
    "order_context": {
      "fields": {
        "merchant_order_id": {
          "source": "auto"
        },
        "order_category": {
          "source": "static",
          "value": "subscription"
        },
        "off_session": {
          "source": "static",
          "value": true
        }
      }
    },
    "amount_information": {
      "fields": {
        "order_tax_amount": {
          "source": "auto"
        },
        "shipping_cost": {
          "source": "auto"
        }
      }
    },
    "environment_configuration": {
      "fields": {
        "test_mode": {
          "source": "static",
          "value": true
        }
      }
    }
  }
}
