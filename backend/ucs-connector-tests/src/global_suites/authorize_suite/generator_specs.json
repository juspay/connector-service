{
  "suite": "authorize",
  "rpc": "PaymentService.Authorize",
  "success": {
    "status": ["CHARGED", "AUTHORIZED"],
    "error": "must_not_exist",
    "must_exist": ["connector_transaction_id"]
  },
  "groups": {
    "required": {
      "fields": {
        "amount": {
          "source": "static",
          "value": {"minor_amount": "auto_generate"},
          "variants": {
            "field": "currency",
            "values": ["USD"]
          }
        },
        "payment_method": {
          "source": "data_file",
          "variants": ["card", "wallet", "upi", "bank_redirect", "bank_transfer", "ach", "pay_later", "crypto", "voucher"]
        },
        "address": {
          "source": "static",
          "value": {
            "shipping_address": {
              "first_name": {"value": "auto_generate"},
              "last_name": {"value": "auto_generate"},
              "line1": {"value": "auto_generate"},
              "line2": {"value": "auto_generate"},
              "line3": {"value": "auto_generate"},
              "city": {"value": "auto_generate"},
              "state": {"value": "CA"},
              "zip_code": {"value": "auto_generate"},
              "country_alpha2_code": "US",
              "email": {"value": "auto_generate"},
              "phone_number": {"value": "auto_generate"},
              "phone_country_code": "+91"
            },
            "billing_address": {
              "first_name": {"value": "auto_generate"},
              "last_name": {"value": "auto_generate"},
              "line1": {"value": "auto_generate"},
              "line2": {"value": "auto_generate"},
              "line3": {"value": "auto_generate"},
              "city": {"value": "auto_generate"},
              "state": {"value": "CA"},
              "zip_code": {"value": "auto_generate"},
              "country_alpha2_code": "US",
              "email": {"value": "auto_generate"},
              "phone_number": {"value": "auto_generate"},
              "phone_country_code": "+91"
            }
          }
        },
        "auth_type": {
          "source": "enum",
          "variants": ["NO_THREE_DS", "THREE_DS"],
          "assertions": {
            "THREE_DS": {"status": ["AUTHENTICATION_PENDING", "AUTHORIZED", "CHARGED"]}
          }
        }
      }
    },
    "identification": {
      "fields": {
        "merchant_transaction_id": {
          "source": "auto"
        }
      }
    },
    "amount_information": {
      "fields": {
        "order_tax_amount": {
          "source": "auto"
        },
        "shipping_cost": {
          "source": "auto"
        }
      }
    },
    "payment_method_and_capture_settings": {
      "fields": {
        "capture_method": {
          "source": "enum",
          "variants": ["AUTOMATIC", "MANUAL"],
          "assertions": {
            "MANUAL": {"status": ["AUTHORIZED"]}
          }
        }
      }
    },
    "customer_information": {
      "fields": {
        "customer.name": {
          "source": "auto"
        },
        "customer.email": {
          "source": "auto"
        },
        "customer.phone_number": {
          "source": "auto"
        },
        "customer.phone_country_code": {
          "source": "static",
          "value": "+1"
        },
        "customer.connector_customer_id": {
          "source": "prev_service",
          "suite": "create_customer",
          "field": "connector_customer_id"
        }
      }
    },
    "authentication_details": {
      "fields": {
        "enrolled_for_3ds": {
          "source": "auto"
        },
        "authentication_data": {
          "source": "auto"
        }
      }
    },
    "urls_for_redirection_and_webhooks": {
      "fields": {
        "return_url": {
          "source": "static",
          "value": "https://example.com/return"
        },
        "webhook_url": {
          "source": "static",
          "value": "https://example.com/webhook"
        },
        "complete_authorize_url": {
          "source": "static",
          "value": ""
        }
      }
    },
    "session_and_token_information": {
      "fields": {
        "session_token": {
          "source": "static",
          "value": ""
        }
      }
    },
    "order_details": {
      "fields": {
        "order_category": {
          "source": "static",
          "value": "physical"
        },
        "merchant_order_id": {
          "source": "auto"
        }
      }
    },
    "behavioral_flags_and_preferences": {
      "fields": {
        "setup_future_usage": {
          "source": "static",
          "value": "OFF_SESSION"
        },
        "off_session": {
          "source": "static",
          "value": true
        },
        "payment_experience": {
          "source": "static",
          "value": "REDIRECT_TO_URL"
        },
        "request_incremental_authorization": {
          "source": "static",
          "value": true
        }
      }
    },
    "contextual_information": {
      "fields": {
        "description": {
          "source": "static",
          "value": "Test order"
        },
        "payment_channel": {
          "source": "static",
          "value": "ECOMMERCE"
        }
      }
    },
    "environment_configuration": {
      "fields": {
        "test_mode": {
          "source": "static",
          "value": true
        }
      }
    },
    "mandate_setup_details": {
      "fields": {
        "setup_mandate_details": {
          "source": "auto"
        }
      }
    },
    "state_information": {
      "fields": {
        "state.access_token.token.value": {
          "source": "prev_service",
          "suite": "create_access_token",
          "field": "access_token.token.value"
        },
        "state.access_token.token_type": {
          "source": "prev_service",
          "suite": "create_access_token",
          "field": "token_type"
        },
        "state.access_token.expires_in_seconds": {
          "source": "prev_service",
          "suite": "create_access_token",
          "field": "expires_in_seconds"
        },
        "state.connector_customer_id": {
          "source": "prev_service",
          "suite": "create_customer",
          "field": "connector_customer_id"
        }
      }
    }
  }
}
