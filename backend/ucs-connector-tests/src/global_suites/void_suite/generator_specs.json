{
  "suite": "void",
  "rpc": "PaymentService.Void",
  "success": {
    "status": ["VOIDED", "PENDING"],
    "error": "must_not_exist",
    "must_exist": ["connector_transaction_id"]
  },
  "groups": {
    "required": {
      "fields": {
        "connector_transaction_id": {
          "source": "prev_service",
          "suite": "authorize"
        },
        "merchant_void_id": {
          "source": "auto"
        },
        "state.access_token.token.value": {
          "source": "prev_service",
          "suite": "create_access_token"
        },
        "state.access_token.token_type": {
          "source": "prev_service",
          "suite": "create_access_token"
        },
        "state.access_token.expires_in_seconds": {
          "source": "prev_service",
          "suite": "create_access_token"
        },
        "state.connector_customer_id": {
          "source": "prev_service",
          "suite": "create_customer"
        }
      }
    },
    "cancellation_reason": {
      "fields": {
        "cancellation_reason": {
          "source": "enum",
          "variants": ["requested_by_customer", "duplicate", "fraudulent"]
        }
      }
    },
    "amount": {
      "fields": {
        "amount": {
          "source": "static",
          "value": {"minor_amount": 6000, "currency": "USD"}
        }
      }
    },
    "order_context": {
      "fields": {
        "merchant_order_id": {
          "source": "auto"
        }
      }
    },
    "environment_configuration": {
      "fields": {
        "test_mode": {
          "source": "static",
          "value": true
        }
      }
    }
  }
}
