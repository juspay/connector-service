# Copy this file to `.env` and fill in your values. `.env` is gitignored.
# Anything set here overrides the corresponding field in config.yml,
# but is itself overridden by an already-exported shell env var.

# Absolute path to the target repo (the one 10XGRACE will run pipelines against).
# Required if config.yml's projectRoot doesn't point at a real directory.
TENXGRACE_PROJECT_ROOT=/absolute/path/to/hyperswitch-prism

# Absolute path to the connector creds.json. SessionManager symlinks this
# into every newly-created session worktree as `<worktree>/creds.json`,
# so the grpc-server and agents find creds at the path preflight checks
# without you having to copy the file into each worktree.
TENXGRACE_CREDS_PATH=/absolute/path/to/creds.json

# LLM gateway credentials. Leave blank to fall back to config.yml's llm.* block.
TENXGRACE_LLM_API_KEY=
TENXGRACE_LLM_BASE_URL=
TENXGRACE_LLM_MODEL=
