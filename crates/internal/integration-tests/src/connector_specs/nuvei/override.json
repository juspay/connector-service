{
  "PaymentService/Authorize": {
    "no3ds_ach_ach_": {
      "grpc_req": {
        "metadata": {}
      }
    },
    "no3ds_fail_payment": {
      "assert": {
        "status": {
          "one_of": [
            "FAILED",
            "DECLINED"
          ]
        },
        "error": {
          "must_exist": true
        }
      }
    },
    "no3ds_eps_": {
      "assert": {
        "connector_transaction_id": {
          "must_exist": false
        }
      }
    },
    "no3ds_giropay_": {
      "assert": {
        "connector_transaction_id": {
          "must_exist": false
        }
      }
    }
  },
  "PaymentService/CreateOrder": {
    "create_order_basic": {
      "assert": {
        "status": {
          "one_of": [
            "INITIATED",
            "REQUIRES_CUSTOMER_ACTION",
            "PENDING"
          ]
        }
      }
    },
    "create_order_with_metadata": {
      "assert": {
        "status": {
          "one_of": [
            "INITIATED",
            "REQUIRES_CUSTOMER_ACTION",
            "PENDING"
          ]
        }
      }
    },
    "create_order_with_payment_method_type": {
      "assert": {
        "session_token": {
          "must_exist": false
        }
      }
    }
  },
  "PaymentService/Void": {
    "void_authorized_payment": {
      "grpc_req": {
        "amount": {
          "minor_amount": 6000,
          "currency": "USD"
        }
      }
    },
    "void_without_cancellation_reason": {
      "grpc_req": {
        "amount": {
          "minor_amount": 6000,
          "currency": "USD"
        }
      }
    }
  }
}