{
  "token_setup_mandate": {
    "grpc_req": {
      "merchant_transaction_id": "auto_generate",
      "amount": {
        "minor_amount": 0,
        "currency": "USD"
      },
      "payment_method_token": {
        "value": ""
      },
      "customer": {
        "id": "auto_generate"
      },
      "mandate_data": {
        "customer_acceptance": {
          "acceptance_type": "online",
          "accepted_at": "auto_generate",
          "online": {
            "ip_address": "127.0.0.1",
            "user_agent": "Mozilla/5.0"
          }
        },
        "mandate_type": {
          "multi_use": {
            "amount": {
              "minor_amount": 10000,
              "currency": "USD"
            },
            "currency": "USD"
          }
        }
      },
      "auth_type": "NO_THREE_DS",
      "test_mode": true
    },
    "assert": {
      "status": {
        "one_of": ["AUTHORIZED", "PROCESSING"]
      },
      "connector_transaction_id": {
        "must_exist": true
      },
      "mandate_id": {
        "must_exist": true
      }
    },
    "is_default": true,
    "display_name": "Saved Token | Setup Mandate"
  }
}
