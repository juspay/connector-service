{
  "suite": "refund",
  "rpc": "PaymentService.Refund",
  "success": {
    "status": ["REFUND_SUCCESS", "PENDING"],
    "error": "must_not_exist",
    "must_exist": ["connector_refund_id"]
  },
  "groups": {
    "required": {
      "fields": {
        "connector_transaction_id": {
          "source": "prev_service",
          "suite": "authorize"
        },
        "merchant_refund_id": {
          "source": "auto"
        },
        "payment_amount": {
          "source": "static",
          "value": 6000
        },
        "refund_amount": {
          "source": "static",
          "value": {"minor_amount": 6000},
          "variants": {
            "field": "currency",
            "values": ["USD", "EUR", "GBP"]
          }
        },
        "state.access_token.token.value": {
          "source": "prev_service",
          "suite": "create_access_token"
        },
        "state.access_token.token_type": {
          "source": "prev_service",
          "suite": "create_access_token"
        },
        "state.access_token.expires_in_seconds": {
          "source": "prev_service",
          "suite": "create_access_token"
        },
        "state.connector_customer_id": {
          "source": "prev_service",
          "suite": "create_customer"
        }
      }
    },
    "partial_refund": {
      "fields": {
        "refund_amount": {
          "source": "static",
          "value": {"minor_amount": 3000, "currency": "USD"}
        }
      }
    },
    "refund_reason": {
      "fields": {
        "reason": {
          "source": "enum",
          "variants": ["customer_requested", "duplicate", "fraudulent"]
        }
      }
    },
    "environment_configuration": {
      "fields": {
        "test_mode": {
          "source": "static",
          "value": true
        }
      }
    }
  }
}
