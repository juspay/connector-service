{
  "suite": "capture",
  "rpc": "PaymentService.Capture",
  "success": {
    "status": ["CHARGED", "PENDING"],
    "error": "must_not_exist",
    "must_exist": ["connector_transaction_id"]
  },
  "groups": {
    "required": {
      "fields": {
        "connector_transaction_id": {
          "source": "prev_service",
          "suite": "authorize"
        },
        "amount_to_capture": {
          "source": "static",
          "value": {"minor_amount": 6000},
          "variants": {
            "field": "currency",
            "values": ["USD", "EUR", "GBP"]
          }
        },
        "merchant_capture_id": {
          "source": "auto"
        },
        "state.access_token.token.value": {
          "source": "prev_service",
          "suite": "create_access_token"
        },
        "state.access_token.token_type": {
          "source": "prev_service",
          "suite": "create_access_token"
        },
        "state.access_token.expires_in_seconds": {
          "source": "prev_service",
          "suite": "create_access_token"
        },
        "state.connector_customer_id": {
          "source": "prev_service",
          "suite": "create_customer"
        }
      }
    },
    "partial_capture": {
      "fields": {
        "amount_to_capture": {
          "source": "static",
          "value": {"minor_amount": 3000, "currency": "USD"}
        }
      }
    },
    "order_context": {
      "fields": {
        "merchant_order_id": {
          "source": "auto"
        }
      }
    },
    "capture_method": {
      "fields": {
        "capture_method": {
          "source": "enum",
          "variants": ["AUTOMATIC", "MANUAL"]
        }
      }
    },
    "environment_configuration": {
      "fields": {
        "test_mode": {
          "source": "static",
          "value": true
        }
      }
    }
  }
}
