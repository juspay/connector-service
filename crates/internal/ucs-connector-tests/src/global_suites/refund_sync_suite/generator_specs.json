{
  "suite": "refund_sync",
  "rpc": "RefundService.Get",
  "success": {
    "status": ["REFUND_SUCCESS", "PENDING"],
    "error": "must_not_exist",
    "must_exist": []
  },
  "groups": {
    "required": {
      "fields": {
        "connector_transaction_id": {
          "source": "prev_service",
          "suite": "authorize"
        },
        "refund_id": {
          "source": "prev_service",
          "suite": "refund"
        },
        "state.access_token.token.value": {
          "source": "prev_service",
          "suite": "create_access_token"
        },
        "state.access_token.token_type": {
          "source": "prev_service",
          "suite": "create_access_token"
        },
        "state.access_token.expires_in_seconds": {
          "source": "prev_service",
          "suite": "create_access_token"
        },
        "state.connector_customer_id": {
          "source": "prev_service",
          "suite": "create_customer"
        }
      }
    },
    "refund_reason": {
      "fields": {
        "refund_reason": {
          "source": "enum",
          "variants": ["customer_requested", "duplicate", "fraudulent"]
        }
      }
    },
    "environment_configuration": {
      "fields": {
        "test_mode": {
          "source": "static",
          "value": true
        }
      }
    }
  }
}
